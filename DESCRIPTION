Package: fiber
Type: Package
Title: Simple Data Structures for Tractography Data in R
Version: 0.1.0
Authors@R: c(
    person(
        given = "Aymeric",
        family = "Stamm",
        role = c("aut", "cre"),
        email = "aymeric.stamm@cnrs.fr",
        comment = c(ORCID = "0000-0002-8725-3654")
